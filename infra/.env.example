# Carregado pelo docker-compose para injetar no container.
# Copie para infra/.env e preencha. NUNCA commite infra/.env.

NODE_ENV=development
LOG_LEVEL=info

# Gerar com: openssl rand -base64 32
APP_KEY=

APP_PORT=3333
APP_URL=http://localhost:3333
VITE_DEV_URL=http://localhost:5173

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=controlla
DB_PASSWORD=
DB_DATABASE=controlla

# Super admin inicial — criado pelo seeder
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
